<Page x:Class="BManagedClient.SignUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BManagedClient"
      Title="Create account" Background="{StaticResource Bg}">
    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="460">
            <Border Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="36,28">
                    <StackPanel>
                        <Border Style="{StaticResource EyebrowPill}" HorizontalAlignment="Center">
                            <TextBlock Text="NEW HERE" Style="{StaticResource Eyebrow}"/>
                        </Border>
                        <TextBlock Text="Create account" Style="{StaticResource DisplayLg}" FontSize="44"
                                   HorizontalAlignment="Center" Margin="0,14,0,4"/>
                        <TextBlock Text="Self-register as a Client. Owner promotes later."
                                   Style="{StaticResource Body}" HorizontalAlignment="Center"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="usernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="Username" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules><local:MinLenth/></Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="PASSWORD" Style="{StaticResource InputLabel}"/>
                        <PasswordBox x:Name="passwordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,10"/>

                        <TextBlock Text="EMAIL" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="emailBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="Email" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules><local:EmailRule/></Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="PHONE" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="phoneBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="Phone" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules><local:PhoneRule/></Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="PREFERRED CURRENCY" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="curBox" Style="{StaticResource ModernCombo}" Margin="0,0,0,18">
                            <ComboBoxItem Content="ILS" IsSelected="True"/>
                            <ComboBoxItem Content="USD"/>
                        </ComboBox>

                        <Button Content="Create account" Click="Create_Click" Style="{StaticResource PrimaryButton}" Height="42"/>
                        <Button Content="← Back to login" Click="Back_Click" Style="{StaticResource GhostButton}" Margin="0,10,0,0"/>
                        <TextBlock x:Name="status" Foreground="{StaticResource Rose}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
