<Page x:Class="BManagedClient.Notifications"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Notifications" Background="{StaticResource Bg}">
    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{StaticResource EyebrowPill}">
                    <TextBlock Text="INBOX" Style="{StaticResource Eyebrow}"/>
                </Border>
                <TextBlock Text="Notifications." Style="{StaticResource DisplayLg}" Margin="0,10,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="✓ Mark all read" Click="MarkAll_Click"
                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Top" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="← Back" Click="Back_Click"
                    Style="{StaticResource SecondaryButton}" VerticalAlignment="Top"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource ShellCard}">
            <Border Style="{StaticResource CoreCard}" Padding="6">
                <ListView x:Name="notifList" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Title"   DisplayMemberBinding="{Binding Title}"   Width="220"/>
                            <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="420"/>
                            <GridViewColumn Header="Type"    DisplayMemberBinding="{Binding NotificationType}" Width="110"/>
                            <GridViewColumn Header="When"    DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM HH:mm}" Width="120"/>
                            <GridViewColumn Header="Read"    DisplayMemberBinding="{Binding IsRead}"  Width="60"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Border>
    </Grid>
</Page>
