<Page x:Class="BManagedClient.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{StaticResource Bg}">
    <Grid Margin="32,28" MaxWidth="640" HorizontalAlignment="Center">
        <Border Style="{StaticResource ShellCard}">
            <Border Style="{StaticResource CoreCard}" Padding="32">
                <StackPanel>
                    <Border Style="{StaticResource EyebrowPill}">
                        <TextBlock Text="ACCOUNT" Style="{StaticResource Eyebrow}"/>
                    </Border>
                    <TextBlock Text="Settings." Style="{StaticResource DisplayLg}" Margin="0,10,0,20"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="emailBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="PHONE" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="phoneBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="PREFERRED CURRENCY" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="curCombo" Style="{StaticResource ModernCombo}" Margin="0,0,0,18">
                        <ComboBoxItem Content="ILS"/>
                        <ComboBoxItem Content="USD"/>
                    </ComboBox>

                    <Button Content="Save profile" Click="Save_Click" Style="{StaticResource PrimaryButton}" Height="40"/>

                    <Border Background="#1A000000" Height="1" Margin="0,22,0,16"/>

                    <TextBlock Text="CHANGE PASSWORD" Style="{StaticResource Eyebrow}" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="newPass" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,10"/>
                    <Button Content="Update password" Click="UpdatePass_Click" Style="{StaticResource AmberButton}" Height="36"/>

                    <TextBlock x:Name="status" Style="{StaticResource Caption}" Margin="0,16,0,0"/>
                    <Button Content="← Back" Click="Back_Click" Style="{StaticResource GhostButton}" Margin="0,16,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
