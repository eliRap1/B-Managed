<Page x:Class="BManagedClient.Invoices"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Invoices" Background="{StaticResource Bg}">
    <Grid Margin="32,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{StaticResource EyebrowPill}">
                    <TextBlock Text="BILLING" Style="{StaticResource Eyebrow}"/>
                </Border>
                <TextBlock Text="Invoices." Style="{StaticResource DisplayLg}" Margin="0,10,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="← Back" Click="Back_Click" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- Left: invoice list -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ShellCard}" Margin="0,0,12,0">
            <Border Style="{StaticResource CoreCard}" Padding="6">
                <ListView x:Name="invoiceList" Background="Transparent" BorderThickness="0" SelectionMode="Single"
                          SelectionChanged="Inv_Selected">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#"      DisplayMemberBinding="{Binding InvoiceNumber}" Width="130"/>
                            <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}"        Width="90"/>
                            <GridViewColumn Header="Total"  DisplayMemberBinding="{Binding Total, StringFormat=N0}" Width="90"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Border>

        <!-- Right: details -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Create new -->
            <Border Grid.Row="0" Style="{StaticResource ShellCard}" Margin="0,0,0,12">
                <Border Style="{StaticResource CoreCard}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="newCustomer" Grid.Column="0" Style="{StaticResource ModernCombo}"
                                  DisplayMemberPath="BusinessName" SelectedValuePath="Id" Margin="0,0,8,0"/>
                        <ComboBox x:Name="newCurrency" Grid.Column="1" Style="{StaticResource ModernCombo}" Margin="0,0,8,0">
                            <ComboBoxItem Content="ILS" IsSelected="True"/>
                            <ComboBoxItem Content="USD"/>
                        </ComboBox>
                        <Button Grid.Column="2" Content="➕ New invoice" Click="Create_Click" Style="{StaticResource MintButton}"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Lines -->
            <Border Grid.Row="1" Style="{StaticResource ShellCard}" Margin="0,0,0,12">
                <Border Style="{StaticResource CoreCard}" Padding="6">
                    <ListView x:Name="lineList" Background="Transparent" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}"  Width="320"/>
                                <GridViewColumn Header="Qty"   DisplayMemberBinding="{Binding Quantity}"            Width="60"/>
                                <GridViewColumn Header="Unit"  DisplayMemberBinding="{Binding UnitPrice, StringFormat=N2}" Width="80"/>
                                <GridViewColumn Header="Total" DisplayMemberBinding="{Binding LineTotal, StringFormat=N2}" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Border>

            <!-- Add line -->
            <Border Grid.Row="2" Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="lineDesc" Grid.Column="0" Style="{StaticResource ModernTextBox}" Margin="0,0,6,0"/>
                        <TextBox x:Name="lineQty"  Grid.Column="1" Style="{StaticResource ModernTextBox}" Margin="0,0,6,0" Text="1"/>
                        <TextBox x:Name="lineUnit" Grid.Column="2" Style="{StaticResource ModernTextBox}" Margin="0,0,6,0" Text="0"/>
                        <Button Grid.Column="3" Content="+ Line" Click="AddLine_Click" Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </Border>
            </Border>

            <!-- Totals + actions -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="totalsText" Style="{StaticResource Display}" FontSize="22"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Mark Sent" Click="Sent_Click" Style="{StaticResource AmberButton}" Margin="0,0,6,0"/>
                    <Button Content="Mark Paid" Click="Paid_Click" Style="{StaticResource MintButton}"  Margin="0,0,6,0"/>
                    <Button Content="📄  Save PDF" Click="Pdf_Click" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
