<Page x:Class="BManagedClient.ManageUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Manage Users" Background="{StaticResource Bg}">
    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{StaticResource EyebrowPill}">
                    <TextBlock Text="ADMIN" Style="{StaticResource Eyebrow}"/>
                </Border>
                <TextBlock Text="Manage users." Style="{StaticResource DisplayLg}" Margin="0,10,0,4"/>
                <TextBlock x:Name="pendingBadge" Style="{StaticResource Caption}" Foreground="{StaticResource Amber}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="← Back" Click="Back_Click" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource ShellCard}">
            <Border Style="{StaticResource CoreCard}" Padding="6">
                <ListView x:Name="userList" Background="Transparent" BorderThickness="0" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Username" DisplayMemberBinding="{Binding Username}" Width="180"/>
                            <GridViewColumn Header="Role"     DisplayMemberBinding="{Binding Role}"     Width="110"/>
                            <GridViewColumn Header="Email"    DisplayMemberBinding="{Binding Email}"    Width="220"/>
                            <GridViewColumn Header="Phone"    DisplayMemberBinding="{Binding Phone}"    Width="130"/>
                            <GridViewColumn Header="Active"   DisplayMemberBinding="{Binding IsActive}" Width="70"/>
                            <GridViewColumn Header="Created"  DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="110"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ShellCard}" Margin="0,12,0,0">
            <Border Style="{StaticResource CoreCard}" Padding="14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox x:Name="roleCombo" Width="140" Style="{StaticResource ModernCombo}" Margin="0,0,8,0">
                        <ComboBoxItem Content="Owner"/>
                        <ComboBoxItem Content="Employee"/>
                        <ComboBoxItem Content="Client"/>
                    </ComboBox>
                    <Button Content="Set Role"        Click="SetRole_Click" Style="{StaticResource PrimaryButton}"   Margin="0,0,6,0"/>
                    <Button Content="Approve / Block" Click="Toggle_Click"  Style="{StaticResource AmberButton}"     Margin="0,0,6,0"/>
                    <Button Content="Reset PW"        Click="ResetPw_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
                    <Button Content="Delete"          Click="Delete_Click"  Style="{StaticResource RoseButton}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
