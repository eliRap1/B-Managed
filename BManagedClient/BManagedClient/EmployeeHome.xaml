<Page x:Class="BManagedClient.EmployeeHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Employee Home" Background="{StaticResource Bg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <Border Style="{StaticResource EyebrowPill}">
                        <TextBlock Text="EMPLOYEE" Style="{StaticResource Eyebrow}"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Hi, " Style="{StaticResource DisplayLg}"/>
                        <TextBlock x:Name="welcome" Style="{StaticResource DisplayLg}" Foreground="{StaticResource Mint}"/>
                        <TextBlock Text="." Style="{StaticResource DisplayLg}"/>
                    </StackPanel>
                    <TextBlock Text="Your work, in one place." Style="{StaticResource Body}" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Click="Notifications_Click" Style="{StaticResource NavButton}"
                        ToolTip="Notifications" VerticalAlignment="Top">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔔" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Notifications"/>
                        </StackPanel>
                        <Border x:Name="notifBadge" Background="{StaticResource Rose}"
                                CornerRadius="999" Padding="6,1" Margin="-12,-8,0,0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock x:Name="notifBadgeText" Text="0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Button>
                <Button Grid.Column="2" Content="Logout" Click="Logout_Click"
                        Style="{StaticResource PrimaryButton}" VerticalAlignment="Top"/>
            </Grid>

            <!-- Stat cards -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ShellCard}" Margin="0,0,8,0">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="ASSIGNED PROJECTS" Style="{StaticResource Eyebrow}"/>
                            <TextBlock x:Name="projectsCount" Text="0" Style="{StaticResource Display}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ShellCard}" Margin="4,0">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="MY EXPENSES" Style="{StaticResource Eyebrow}"/>
                            <TextBlock x:Name="expensesCount" Text="0" Style="{StaticResource Display}"
                                       Foreground="{StaticResource Rose}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ShellCard}" Margin="8,0,0,0">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="UNREAD NOTIFICATIONS" Style="{StaticResource Eyebrow}"/>
                            <TextBlock x:Name="notifCount" Text="0" Style="{StaticResource Display}"
                                       Foreground="{StaticResource Amber}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>

            <!-- Quick actions -->
            <Border Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="QUICK ACTIONS" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="📁  My projects"   Click="Projects_Click"
                                    Style="{StaticResource PrimaryButton}"   Height="56" Margin="4"/>
                            <Button Grid.Column="1" Content="💸  Log expense"   Click="Expenses_Click"
                                    Style="{StaticResource RoseButton}"      Height="56" Margin="4"/>
                            <Button Grid.Column="2" Content="🔔  Notifications" Click="Notifications_Click"
                                    Style="{StaticResource SecondaryButton}" Height="56" Margin="4"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Projects list -->
            <Border Style="{StaticResource ShellCard}" Margin="0,16,0,0">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="MY ASSIGNED PROJECTS" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <ListView x:Name="projectsList" Background="Transparent" BorderThickness="0" Height="280">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Title"    DisplayMemberBinding="{Binding Title}"   Width="240"/>
                                    <GridViewColumn Header="Status"   DisplayMemberBinding="{Binding Status}"  Width="140"/>
                                    <GridViewColumn Header="Due"      DisplayMemberBinding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                                    <GridViewColumn Header="Budget"   DisplayMemberBinding="{Binding TotalBudget, StringFormat=N2}"     Width="120"/>
                                    <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}" Width="80"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
