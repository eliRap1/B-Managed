<Page x:Class="BManagedClient.EmployeeHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Employee Home" Background="{StaticResource Bg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28">
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <Border Style="{StaticResource EyebrowPill}">
                        <TextBlock Text="EMPLOYEE" Style="{StaticResource Eyebrow}"/>
                    </Border>
                    <TextBlock x:Name="welcome" Style="{StaticResource DisplayLg}" Margin="0,12,0,4"/>
                    <TextBlock Text="Your assigned projects." Style="{StaticResource Body}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Logout" Click="Logout_Click"
                        Style="{StaticResource PrimaryButton}" VerticalAlignment="Top"/>
            </Grid>

            <Border Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="20">
                    <ListView x:Name="projectsList" Background="Transparent" BorderThickness="0" Height="420">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title"    DisplayMemberBinding="{Binding Title}"   Width="240"/>
                                <GridViewColumn Header="Status"   DisplayMemberBinding="{Binding Status}"  Width="140"/>
                                <GridViewColumn Header="Due"      DisplayMemberBinding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                                <GridViewColumn Header="Budget"   DisplayMemberBinding="{Binding TotalBudget, StringFormat=N2}"     Width="110"/>
                                <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}" Width="80"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
