<Page x:Class="BManagedClient.ClientHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Client Home" Background="{StaticResource Bg}">
    <Grid Margin="32,40">
        <Border Style="{StaticResource ShellCard}" MaxWidth="640" HorizontalAlignment="Center">
            <Border Style="{StaticResource CoreCard}" Padding="40,32">
                <StackPanel>
                    <Border Style="{StaticResource EyebrowPill}">
                        <TextBlock Text="CLIENT PORTAL" Style="{StaticResource Eyebrow}"/>
                    </Border>
                    <TextBlock x:Name="welcome" Style="{StaticResource DisplayLg}" Margin="0,12,0,8"/>
                    <TextBlock Text="Use the web portal for full features (invoices, downloads). Logout when done."
                               Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <Button Content="Logout" Click="Logout_Click" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
