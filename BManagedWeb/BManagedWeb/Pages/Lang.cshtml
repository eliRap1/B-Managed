@page
@{
    var t = Request.Query["target"].ToString();
    if (t == "he" || t == "en") HttpContext.Session.SetString("Lang", t);

    // Pick a safe destination — Referer can point back at /Lang and cause a
    // redirect loop on rapid double-clicks. Use the user's role landing page.
    var role = HttpContext.Session.GetString("Role") ?? "";
    string back = role switch
    {
        "Owner"    => "/Owner/Home",
        "Employee" => "/Employee/Home",
        "Client"   => "/Client/Portal",
        _          => "/Login",
    };

    // If Referer is something other than /Lang and points at the same host,
    // honour it so the user stays on the page they were viewing.
    var refer = Request.Headers["Referer"].ToString() ?? "";
    if (!string.IsNullOrEmpty(refer) && !refer.Contains("/Lang"))
        back = refer;

    Response.Redirect(back);
}
