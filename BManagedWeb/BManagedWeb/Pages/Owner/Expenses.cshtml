@page
@model BManagedWeb.Pages.Owner.ExpensesModel
@{ ViewData["Title"] = "Expenses"; }

<div class="reveal mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
        <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">Outflows</span>
        <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">Expenses.</h1>
    </div>
    <form method="get" class="flex items-center gap-3 text-sm">
        <input asp-for="Q" placeholder="Search vendor / descriptionвА¶"
               class="bg-paper-100 border border-black/5 rounded-full px-4 py-2 outline-none focus:border-accent" />
        <button class="bg-ink text-paper-50 rounded-full px-4 py-2">Search</button>
        <a asp-page-handler="Csv" class="bg-mint text-white rounded-full px-4 py-2">CSV</a>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="reveal mb-6 px-4 py-2 rounded-full inline-block @(Model.IsSuccess ? "bg-mint/10 text-mint border border-mint/20" : "bg-rose/10 text-rose border border-rose/20")">@Model.Message</div>
}

<!-- Cheat-sheet card explaining the two amount fields -->
<div class="reveal mb-6 max-w-3xl bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
    <div class="bg-paper-50 rounded-core p-5 shadow-inset text-sm text-ink/70">
        <div class="pill text-ink/40 mb-2">How to log an expense</div>
        <p class="mb-1">
            <span class="font-semibold">Amount (gross)</span> вАФ
            total you paid, VAT included. e.g. a 117 вВ™ supplier bill вЖТ enter 117.
        </p>
        <p>
            <span class="font-semibold">VAT paid</span> вАФ
            only the VAT portion you can later deduct. From 117 вЖТ VAT = 17. Click Auto-VAT to fill it from the gross amount automatically.
        </p>
    </div>
</div>

<form method="post" asp-page-handler="Add" enctype="multipart/form-data" class="reveal mb-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 max-w-4xl">
    <div class="bg-paper-50 rounded-core p-6 shadow-inset grid md:grid-cols-4 gap-3">
        <select asp-for="NewCategoryId" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5">
            <option value="0">CategoryвА¶</option>
            @foreach (var c in Model.Categories)
            { <option value="@c.Id">@c.Name</option> }
        </select>
        <input asp-for="NewVendor" placeholder="Vendor" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
        <div class="relative">
            <input asp-for="NewAmount" id="exp-amount" type="number" step="0.01"
                   placeholder="Amount (gross, incl. VAT)"
                   title="Total paid to supplier, VAT included"
                   class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
        </div>
        <div class="relative flex items-center gap-1">
            <input asp-for="NewVat" id="exp-vat" type="number" step="0.01"
                   placeholder="VAT (deductible)"
                   title="Only the VAT portion of the gross amount"
                   class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
            <button type="button" id="exp-autovat"
                    class="shrink-0 bg-ink text-paper-50 rounded-full px-3 py-1.5 text-xs"
                    title="Auto = Amount √Ч 18 √Ј 118 (Israeli VAT, since 2025)">
                Auto&nbsp;18%
            </button>
        </div>
        <input asp-for="NewDescription" placeholder="Description" class="md:col-span-3 bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
        <select asp-for="NewCurrency" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5">
            <option>ILS</option><option>USD</option>
        </select>
        <select asp-for="NewRecurringKind"
                title="Mark recurring („Ф„Х„¶„Р„Ф „І„С„Х„Ґ„Ф / „Ю„©„™„†„Ф)"
                class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5">
            <option value="">One-time</option>
            <option value="Fixed">Recurring ¬Ј Fixed (rent, insurance)</option>
            <option value="Variable">Recurring ¬Ј Variable (utilities)</option>
        </select>
        <label class="md:col-span-4 bg-paper-100 border border-dashed border-black/10 rounded-2xl px-4 py-3 text-sm text-ink/60 cursor-pointer hover:border-accent transition flex items-center gap-3">
            <span class="pill">Receipt (optional, вЙ§5 MB)</span>
            <input asp-for="NewReceipt" type="file" accept="image/*,application/pdf" class="text-xs" />
        </label>
        <button class="md:col-span-4 bg-rose text-white rounded-full px-6 py-3 mt-1 active:scale-[0.98]">Log expense</button>
    </div>
</form>

@section Scripts {
<script>
  // Auto-VAT: gross √Ч 18 √Ј 118 (Israeli standard rate since Jan 2025).
  const amount = document.getElementById('exp-amount');
  const vat    = document.getElementById('exp-vat');
  const btn    = document.getElementById('exp-autovat');
  function calc() {
    const g = parseFloat(amount.value);
    if (!isFinite(g) || g <= 0) return;
    vat.value = (g * 18 / 118).toFixed(2);
  }
  if (btn) btn.addEventListener('click', calc);
  if (amount) amount.addEventListener('input', () => {
    if (!vat.value || parseFloat(vat.value) === 0) calc();
  });

  // Smart classification: vendor keyword вЖТ category dropdown auto-pick.
  const VENDOR_RULES = [
    { rx: /(„©„Х„§„®„°„Ь|„®„Ю„Щ „Ь„Х„Щ|„Р„Х„©„® „Ґ„У|„Щ„Х„Ч„†„†„Х„£|„Ю„Т„Ф|„Х„Щ„І„Ш„Х„®„Щ|„Ш„Щ„С „Ш„Ґ„Э|shufersal|rami\s*levy|carrefour|am-pm|coffee|cafe|„Ю„°„Ґ„У„Ф|„§„Щ„¶„Ф|„І„§„Ф)/i, cat: "Food" },
    { rx: /(„У„Ь„І|„§„Ц|„°„Х„†„Х„Ь|„У„Х„® „Р„Ь„Х„Я|delek|paz|sonol|„Ч„†„Щ„Х„Я|parking)/i,                                                            cat: "Fuel" },
    { rx: /(„©„Ы„Щ„®„Х„™|„†„У„Ь[„і"„≥]„Я|rent)/i,                                                                                            cat: "Rent" },
    { rx: /(„Ч„©„Ю„Ь|„Ю„Щ„Э|„С„Ц„І|hot|cellcom|partner|„§„Ь„Р„§„Х„Я|orange|electricity|water)/i,                                                cat: "Utilities" },
    { rx: /(facebook|instagram|google\s*ads|tiktok|„Ь„Щ„†„І„У„Р„Щ„Я|„Ю„Щ„™„Х„Т|„§„®„°„Х„Э|advertising|marketing)/i,                                cat: "Marketing" },
    { rx: /(„Р„Ь[÷Њ-]„Ґ„Ь|„®„Ы„С„™|„Ю„Ш„Х„°|„Ю„Ь„Х„Я|airbnb|booking|train|flight|„†„°„Щ„Ґ„Ф)/i,                                                       cat: "Travel" },
    { rx: /(„¶„Щ„Х„У|„Ь„§„Ш„Х„§|„Ю„Ч„©„С|hp|dell|apple|equipment|hardware|„Ы„Ь„Щ„Э)/i,                                                            cat: "Equipment" },
  ];
  const vendorBox  = document.querySelector('input[name="NewVendor"]');
  const descBox    = document.querySelector('input[name="NewDescription"]');
  const catSelect  = document.querySelector('select[name="NewCategoryId"]');
  function autoClassify() {
    if (!catSelect || !catSelect.options) return;
    if (catSelect.value && catSelect.value !== "0") return;          // user picked вЖТ don't override
    const text = ((vendorBox && vendorBox.value) || "") + " " + ((descBox && descBox.value) || "");
    if (!text.trim()) return;
    for (const r of VENDOR_RULES) {
      if (!r.rx.test(text)) continue;
      for (const opt of catSelect.options) {
        if ((opt.text || "").toLowerCase() === r.cat.toLowerCase()) {
          catSelect.value = opt.value;
          return;
        }
      }
    }
  }
  if (vendorBox) vendorBox.addEventListener('input', autoClassify);
  if (descBox)   descBox.addEventListener('input', autoClassify);
</script>
}

<section class="reveal bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
    <div class="bg-paper-50 rounded-core p-6 shadow-inset">
        <table class="w-full text-sm">
            <thead><tr class="text-ink/40 pill">
                <th class="text-left py-2">Date</th><th class="text-left">Category</th>
                <th class="text-left">Vendor</th><th class="text-right">Amount</th>
                <th class="text-right">VAT</th><th class="text-right">Currency</th>
                <th class="text-center">Recurring</th>
            </tr></thead>
            <tbody>
            @foreach (var e in Model.Expenses)
            {
                var catName = Model.Categories.FirstOrDefault(c => c.Id == (e.CategoryId ?? 0))?.Name ?? "вАФ";
                <tr class="border-t border-black/5">
                    <td class="py-2">@e.Date.ToString("dd MMM yy")</td>
                    <td>@catName</td>
                    <td>@e.Vendor</td>
                    <td class="text-right font-medium">@e.Amount.ToString("N2")</td>
                    <td class="text-right text-ink/60">@e.VatPaid.ToString("N2")</td>
                    <td class="text-right text-ink/40 text-xs">@e.Currency</td>
                    <td class="text-center">
                        <form method="post" asp-page-handler="Mark" class="inline-flex items-center gap-1">
                            <input type="hidden" name="id" value="@e.Id" />
                            @{ var kind = e.RecurringKind ?? ""; }
                            <select name="kind" onchange="this.form.requestSubmit()"
                                    class="bg-paper-100 border border-black/5 rounded-full px-2 py-1 text-xs">
                                <option value=""         selected="@(kind == ""         ? "selected" : null)">вАФ</option>
                                <option value="Fixed"    selected="@(kind == "Fixed"    ? "selected" : null)">Fixed</option>
                                <option value="Variable" selected="@(kind == "Variable" ? "selected" : null)">Variable</option>
                            </select>
                        </form>
                    </td>
                </tr>
            }
            @if (Model.Expenses.Count == 0)
            { <tr><td colspan="7" class="text-center py-12 text-ink/40">No expenses yet.</td></tr> }
            </tbody>
        </table>
    </div>
</section>
