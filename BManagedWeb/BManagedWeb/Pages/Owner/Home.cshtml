@page
@model BManagedWeb.Pages.Owner.HomeModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Eyebrow + headline -->
<div class="reveal mb-12">
    <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Owner","בעלים")</span>
    <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">
        @L.T(HttpContext,"Hi,","שלום,") @Model.Username.<br/>
        <span class="text-ink/40">@L.T(HttpContext,"Here's your money,","הנה הכסף שלך,")</span>
        <span class="text-accent">@L.T(HttpContext,"in motion.","בתנועה.")</span>
    </h1>
</div>

<!-- ASYMMETRICAL BENTO ===================================== -->
<section class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">

    <!-- Big card: Outstanding balance -->
    <div class="reveal md:col-span-8 md:row-span-2 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-soft">
        <div class="bg-paper-50 rounded-core p-8 md:p-10 shadow-inset h-full">
            <div class="flex items-center justify-between mb-8">
                <span class="pill text-ink/40">@L.T(HttpContext,"Outstanding","יתרה לגביה")</span>
                <span class="text-xs text-ink/40">@Model.TodayLabel</span>
            </div>
            <div class="display text-7xl md:text-[8rem] font-bold leading-[0.85] tracking-tighter">
                @Model.UnpaidTotalDisplay
                <span class="text-ink/30 text-3xl align-top">@Model.Currency</span>
            </div>
            <div class="mt-10 flex flex-wrap gap-x-10 gap-y-4 text-sm">
                <div><span class="block text-ink/40 pill">@L.T(HttpContext,"Unpaid","לא שולם")</span><span class="display text-2xl font-semibold">@Model.UnpaidCount</span></div>
                <div><span class="block text-ink/40 pill">@L.T(HttpContext,"Overdue","באיחור")</span><span class="display text-2xl font-semibold text-rose">@Model.OverdueCount</span></div>
                <div><span class="block text-ink/40 pill">@L.T(HttpContext,"Active projects","פרויקטים פעילים")</span><span class="display text-2xl font-semibold">@Model.ActiveProjects</span></div>
                <div><span class="block text-ink/40 pill">@L.T(HttpContext,"Customers","לקוחות")</span><span class="display text-2xl font-semibold">@Model.CustomersCount</span></div>
            </div>
        </div>
    </div>

    <!-- VAT due -->
    <div class="reveal md:col-span-4 bg-ink ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-ink-soft rounded-core p-8 text-paper-50 shadow-inset h-full">
            <span class="pill text-paper-50/50">@L.T(HttpContext,"VAT due (this month)","מע״מ לתשלום (החודש)")</span>
            <div class="display text-5xl font-bold mt-3">@Model.VatDueDisplay <span class="text-base text-paper-50/50">@Model.Currency</span></div>
            <div class="text-paper-50/50 text-xs mt-2">@L.T(HttpContext,"Set aside","להפריש"): @Model.TaxSetAsideDisplay @Model.Currency</div>
        </div>
    </div>

    <!-- 6-month profit sparkline -->
    <div class="reveal md:col-span-4 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-soft">
        <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
            <div class="flex items-center justify-between">
                <span class="pill text-ink/40">@L.T(HttpContext,"6-month profit","רווח 6 חודשים")</span>
                <span class="text-xs text-ink/40" id="spark-last">—</span>
            </div>
            <canvas id="spark" height="140" class="mt-3" style="max-height:200px"></canvas>
        </div>
    </div>

    <!-- KPI quick-glance tiles (aging, on-time, concentration, debt) -->
    <div class="reveal md:col-span-6 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
            <div class="flex items-center justify-between mb-3">
                <span class="pill text-ink/40">@L.T(HttpContext,"Receivables aging","יתרת חייבים")</span>
                <a asp-page="/Owner/Reports" class="text-xs text-accent hover:underline">@L.T(HttpContext,"Details","פירוט") →</a>
            </div>
            <div class="display text-3xl font-bold">@Model.Kpis.TotalOutstanding.ToString("N0") <span class="text-base text-ink/40">@Model.Currency</span></div>
            <div class="grid grid-cols-4 gap-2 mt-4 text-xs">
                <div class="bg-mint/10 rounded-xl px-2 py-2 text-center">
                    <div class="pill text-ink/40">@L.T(HttpContext,"Current","שוטף")</div>
                    <div class="font-semibold mt-1">@Model.Kpis.AgingCurrent.ToString("N0")</div>
                </div>
                <div class="bg-amber/10 rounded-xl px-2 py-2 text-center">
                    <div class="pill text-ink/40">1–30</div>
                    <div class="font-semibold mt-1">@Model.Kpis.Aging1To30.ToString("N0")</div>
                </div>
                <div class="bg-amber/15 rounded-xl px-2 py-2 text-center">
                    <div class="pill text-ink/40">31–60</div>
                    <div class="font-semibold mt-1">@Model.Kpis.Aging31To60.ToString("N0")</div>
                </div>
                <div class="bg-rose/10 rounded-xl px-2 py-2 text-center">
                    <div class="pill text-ink/40">61+</div>
                    <div class="font-semibold mt-1 text-rose">@Model.Kpis.Aging61Plus.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="reveal md:col-span-3 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
            <span class="pill text-ink/40">@L.T(HttpContext,"On-time payments","תשלומים בזמן")</span>
            <div class="display text-3xl font-bold mt-3">@(Model.Kpis.OnTimeRatePct <= 0 ? "—" : Model.Kpis.OnTimeRatePct.ToString("N1") + "%")</div>
            <div class="text-xs text-ink/50 mt-1">
                @L.T(HttpContext,"Avg","ממוצע"):
                @(Model.Kpis.AvgDaysToPayment <= 0 ? "—" : Model.Kpis.AvgDaysToPayment.ToString("N1") + " " + L.T(HttpContext,"days","ימים"))
            </div>
            @if (!string.IsNullOrEmpty(Model.Kpis.TopCustomerName))
            {
                <div class="text-xs text-ink/50 mt-3 border-t border-black/5 pt-2">
                    @L.T(HttpContext,"Top customer","לקוח מרכזי"):
                    <span class="font-semibold">@Model.Kpis.TopCustomerName</span> ·
                    @Model.Kpis.TopCustomerSharePct.ToString("N1")%
                </div>
            }
        </div>
    </div>

    @if (Model.Loans != null && Model.Loans.LoanCount > 0)
    {
        <div class="reveal md:col-span-3 bg-amber/15 ring-1 ring-amber/30 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                <div class="flex items-center justify-between mb-2">
                    <span class="pill text-ink/40">@L.T(HttpContext,"Loans (קרן)","הלוואות (קרן)")</span>
                    <a asp-page="/Owner/Loans" class="text-xs text-accent hover:underline">@L.T(HttpContext,"Manage","ניהול") →</a>
                </div>
                <div class="display text-3xl font-bold">@Model.Loans.TotalRemaining.ToString("N0") <span class="text-base text-ink/40">@Model.Currency</span></div>
                <div class="text-xs text-ink/50 mt-1">
                    @Model.Loans.LoanCount @L.T(HttpContext,"active","פעילות")
                    @if (Model.Loans.KerenBackedCount > 0)
                    { <text>· @Model.Loans.KerenBackedCount @L.T(HttpContext,"state-backed","בערבות")</text> }
                </div>
                @if (Model.Loans.MonthlyDebtServiceRatioPct > 0)
                {
                    var color = Model.Loans.MonthlyDebtServiceRatioPct >= 40 ? "text-rose"
                              : Model.Loans.MonthlyDebtServiceRatioPct >= 25 ? "text-amber" : "text-ink";
                    <div class="text-xs mt-3 border-t border-black/5 pt-2 @color">
                        @L.T(HttpContext,"Monthly burden","נטל חודשי"): @Model.Loans.MonthlyDebtServiceRatioPct.ToString("N1")%
                        @L.T(HttpContext,"of income","מההכנסה")
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="reveal md:col-span-3 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full flex flex-col">
                <span class="pill text-ink/40">@L.T(HttpContext,"Loans (קרן)","הלוואות (קרן)")</span>
                <div class="display text-3xl font-bold mt-3">@L.T(HttpContext,"None","אין")</div>
                <div class="text-xs text-ink/50 mt-auto">
                    <a asp-page="/Owner/Loans" class="text-accent hover:underline">@L.T(HttpContext,"+ Track a business loan","+ הוסף הלוואה עסקית")</a>
                </div>
            </div>
        </div>
    }

    @if (Model.Forecast != null && Model.Forecast.Count > 0)
    {
        <div class="reveal md:col-span-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset">
                <span class="pill text-ink/40">@L.T(HttpContext,"3-month cashflow forecast","תחזית תזרים 3 חודשים")</span>
                <p class="text-xs text-ink/40 mt-1">
                    @L.T(HttpContext,"Trailing-3-month average + outstanding invoices due in each month.",
                                      "ממוצע 3 חודשים אחרונים + חשבוניות פתוחות לפי תאריך פירעון.")
                </p>
                <div class="grid md:grid-cols-3 gap-3 mt-4">
                    @{ var fIdx = 0; var anchor = DateTime.Today; }
                    @foreach (var f in Model.Forecast)
                    {
                        fIdx++;
                        var monthLabel = anchor.AddMonths(fIdx).ToString("MMM yyyy");
                        var posClass = f.Profit >= 0 ? "text-mint" : "text-rose";
                        <div class="bg-paper-100 rounded-2xl px-5 py-4">
                            <div class="pill text-ink/40">@monthLabel</div>
                            <div class="text-sm mt-1">@L.T(HttpContext,"Income","הכנסות"): <span class="font-semibold">@f.Income.ToString("N0") @f.DisplayCurrency</span></div>
                            <div class="text-sm">@L.T(HttpContext,"Expenses","הוצאות"): <span class="font-semibold">@f.Expenses.ToString("N0") @f.DisplayCurrency</span></div>
                            <div class="display text-2xl font-semibold mt-2 @posClass">@f.Profit.ToString("N0") <span class="text-ink/40 text-xs">@f.DisplayCurrency</span></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.HasInsights)
    {
        <div class="reveal md:col-span-12 bg-amber/10 border border-amber/20 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset">
                <span class="pill text-amber">@L.T(HttpContext,"Smart insights","תובנות חכמות")</span>
                <ul class="mt-2 text-sm text-ink/70 space-y-1">
                    @if (!string.IsNullOrEmpty(Model.TopExpenseCategory))
                    {
                        <li>💸
                            @L.T(HttpContext,"Biggest expense this month","ההוצאה הגדולה החודש"):
                            <span class="font-semibold">@Model.TopExpenseCategory</span> ·
                            @Model.TopExpenseAmount.ToString("N0") @Model.Currency
                        </li>
                    }
                    @if (Model.RevenueChangePct != 0)
                    {
                        var arrow = Model.RevenueChangePct > 0 ? "📈" : "📉";
                        var color = Model.RevenueChangePct > 0 ? "text-mint" : "text-rose";
                        <li>@arrow
                            @L.T(HttpContext,"Revenue vs last month","הכנסות מול חודש קודם"):
                            <span class="font-semibold @color">@(Model.RevenueChangePct > 0 ? "+" : "")@Model.RevenueChangePct%</span>
                        </li>
                    }
                    @if (Model.BusinessType == "Patur" || Model.BusinessType == "Zair")
                    {
                        <li>ℹ️
                            @L.T(HttpContext,"Account type:","סוג חשבון:")
                            <span class="font-semibold">@(Model.BusinessType == "Patur" ? "עוסק פטור" : "עוסק זעיר")</span> —
                            @L.T(HttpContext,"new invoices issued without VAT.","חשבוניות מונפקות ללא מע״מ.")
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    <!-- Recent invoices -->
    <div class="reveal md:col-span-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-soft">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset">
            <div class="flex items-center justify-between mb-6">
                <h2 class="display text-2xl font-semibold">@L.T(HttpContext,"Recent invoices","חשבוניות אחרונות")</h2>
                <a asp-page="/Owner/Invoices" class="text-sm text-accent hover:underline">@L.T(HttpContext,"View all","הצג הכל") →</a>
            </div>

            @if (Model.RecentInvoices == null || Model.RecentInvoices.Count == 0)
            {
                <p class="text-ink/40 text-sm">@L.T(HttpContext,"No invoices yet — issue your first one to start tracking revenue.","אין חשבוניות עדיין — הוצא את הראשונה כדי להתחיל לעקוב אחר ההכנסות.")</p>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var inv in Model.RecentInvoices)
                    {
                        var color = inv.Status switch { "Paid" => "mint", "Overdue" => "rose", _ => "amber" };
                        <div class="flex items-center justify-between bg-paper-100 rounded-2xl px-5 py-4 border border-black/5">
                            <div>
                                <div class="text-xs text-ink/40">@inv.InvoiceNumber</div>
                                <div class="font-medium">@inv.CustomerName</div>
                            </div>
                            <div class="text-right">
                                <div class="display font-semibold">@inv.Total.ToString("N0") <span class="text-ink/40 text-xs">@inv.Currency</span></div>
                                <div class="pill rounded-full px-2 py-0.5 mt-1 inline-block bg-@(color)/10 text-@(color) border border-@(color)/20">@inv.Status</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  // Polling: refresh /Owner/Home?handler=Stats every 15 seconds for live counters.
  setInterval(async () => {
    try {
      const r = await fetch('/Owner/Home?handler=Stats');
      if (!r.ok) return;
      const d = await r.json();
      document.querySelectorAll('[data-stat]').forEach(el => {
        const k = el.getAttribute('data-stat');
        if (d[k] !== undefined) el.textContent = d[k];
      });
    } catch (e) {}
  }, 15000);

  // Sparkline render
  (async () => {
    try {
      const r = await fetch('/Owner/Home?handler=Sparkline');
      if (!r.ok) return;
      const d = await r.json();
      const ctx = document.getElementById('spark');
      if (!ctx || !d.labels) return;
      const last = d.data && d.data.length ? d.data[d.data.length - 1] : 0;
      document.getElementById('spark-last').textContent =
        Math.round(Number(last)).toLocaleString() + ' ' + (d.currency || '');
      // Pad y-axis so the line never hits the very bottom or top of the canvas.
      const dataMin = Math.min(0, ...d.data);
      const dataMax = Math.max(...d.data, 0);
      const pad     = Math.max(50, (dataMax - dataMin) * 0.15);
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: d.labels,
          datasets: [{
            data: d.data,
            borderColor: '#3B5BFF',
            backgroundColor: 'rgba(59, 91, 255, 0.08)',
            fill: true,
            tension: 0.35,
            pointRadius: 3,
            pointBackgroundColor: '#3B5BFF',
            borderWidth: 2,
          }],
        },
        options: {
          plugins: { legend: { display: false } },
          scales: {
            x: { display: true, ticks: { font: { size: 10 } }, grid: { display: false } },
            y: { display: false, suggestedMin: dataMin - pad, suggestedMax: dataMax + pad },
          },
          maintainAspectRatio: false,
          responsive: true,
          animation: false,
        },
      });
    } catch (e) {}
  })();
</script>
}
