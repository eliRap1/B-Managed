@page
@model BManagedWeb.Pages.SignUpModel
@{ ViewData["Title"] = "Create account"; }

<section class="reveal min-h-[80dvh] grid place-items-center">
    <div class="w-full max-w-xl">
        <div class="flex justify-center mb-6">
            <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">New here</span>
        </div>
        <h1 class="display text-5xl md:text-6xl font-bold text-center text-ink mb-2">Create account</h1>
        <p id="subtitle" class="text-center text-ink/50 mb-10">Pick the role that fits you.</p>

        @* Step 1: role picker *@
        @{ var roleStepClass = string.IsNullOrEmpty(Model.SelectedRole) ? "" : "hidden"; }
        @{ var formStepClass = string.IsNullOrEmpty(Model.SelectedRole) ? "hidden" : ""; }
        @{ var ownerOnlyClass = Model.SelectedRole == "Owner" ? "" : "hidden"; }
        @{ var inviteOnlyClass = (Model.SelectedRole == "Employee" || Model.SelectedRole == "Client") ? "" : "hidden"; }
        @{
            var roleBadgeText = Model.SelectedRole switch
            {
                "Owner"    => "OWNER",
                "Employee" => "EMPLOYEE",
                "Client"   => "CLIENT",
                _          => ""
            };
        }
        <div id="roleStep" class="grid md:grid-cols-3 gap-4 @roleStepClass">
            <button type="button" onclick="pickRole('Owner')"
                    class="text-left bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 hover:shadow-float transition-all duration-500 ease-spring">
                <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                    <div class="text-3xl mb-3">🏢</div>
                    <div class="display text-2xl font-bold mb-2">Owner — I run a business</div>
                    <p class="text-sm text-ink/60">
                        Manage customers, projects, invoices, expenses and VAT. Pick Osek Patur or Murshe.
                    </p>
                    <div class="mt-3 inline-flex items-center gap-2 bg-mint text-white rounded-full px-4 py-1.5 text-sm">
                        Continue as Owner →
                    </div>
                </div>
            </button>
            <button type="button" onclick="pickRole('Employee')"
                    class="text-left bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 hover:shadow-float transition-all duration-500 ease-spring">
                <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                    <div class="text-3xl mb-3">👤</div>
                    <div class="display text-2xl font-bold mb-2">Employee — I work on assigned projects</div>
                    <p class="text-sm text-ink/60">
                        Pick the company you work for, log expenses, see your tasks. Owner approves before activation.
                    </p>
                    <div class="mt-3 inline-flex items-center gap-2 bg-ink text-paper-50 rounded-full px-4 py-1.5 text-sm">
                        Continue as Employee →
                    </div>
                </div>
            </button>
            <button type="button" onclick="pickRole('Client')"
                    class="text-left bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 hover:shadow-float transition-all duration-500 ease-spring">
                <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                    <div class="text-3xl mb-3">🛍️</div>
                    <div class="display text-2xl font-bold mb-2">Client — I'm a customer of a business</div>
                    <p class="text-sm text-ink/60">
                        View your invoices, projects, and contracts. Use the invite code your business sent you.
                    </p>
                    <div class="mt-3 inline-flex items-center gap-2 bg-amber text-white rounded-full px-4 py-1.5 text-sm">
                        Continue as Client →
                    </div>
                </div>
            </button>
            <p class="md:col-span-3 text-center text-xs text-ink/40 mt-2">
                Already have an account?
                <a asp-page="/Login" class="text-accent hover:underline">Sign in</a>
            </p>
        </div>

        @* Step 2: form *@
        <div id="formStep" class="@formStepClass">
            <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-float">
                <div class="bg-paper-50 rounded-core shadow-inset p-8">
                    <form method="post" class="space-y-4">
                        <input asp-for="SelectedRole" type="hidden" id="selectedRoleHidden" value="@Model.SelectedRole"/>

                        <div class="flex items-center justify-between">
                            <span id="roleBadge" class="pill rounded-full px-3 py-1 bg-mint/10 text-mint border border-mint/20 text-xs">@roleBadgeText</span>
                            <button type="button" onclick="goBackToRole()" class="text-xs text-ink/50 hover:underline">← Change role</button>
                        </div>

                        <div>
                            <label class="pill text-ink/40 mb-2 block">Username</label>
                            <input asp-for="Username" autocomplete="username"
                                   minlength="4" maxlength="20" pattern="[A-Za-z0-9_.]{4,20}" required
                                   data-validate="username"
                                   class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition invalid:border-rose invalid:bg-rose/5" />
                            <p class="text-xs text-ink/40 mt-1">4–20 letters, digits, _ or .</p>
                            <p data-error="username" class="text-xs text-rose mt-1 hidden"></p>
                        </div>
                        <div>
                            <label class="pill text-ink/40 mb-2 block">Password</label>
                            <input asp-for="Password" type="password" autocomplete="new-password"
                                   id="pwField" minlength="8" required data-validate="password"
                                   class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition invalid:border-rose invalid:bg-rose/5" />
                            <div id="pwHint" class="mt-1 text-xs space-y-0.5">
                                <div data-rule="len"   class="text-ink/40">• At least 8 characters</div>
                                <div data-rule="alpha" class="text-ink/40">• Contains a letter</div>
                                <div data-rule="num"   class="text-ink/40">• Contains a digit</div>
                            </div>
                            <p data-error="password" class="text-xs text-rose mt-1 hidden"></p>
                        </div>
                        <div>
                            <label class="pill text-ink/40 mb-2 block">Email</label>
                            <input asp-for="Email" type="email" autocomplete="email" required
                                   data-validate="email"
                                   class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition invalid:border-rose invalid:bg-rose/5" />
                            <p data-error="email" class="text-xs text-rose mt-1 hidden"></p>
                        </div>
                        <div>
                            <label class="pill text-ink/40 mb-2 block">Phone</label>
                            <input asp-for="Phone" type="tel" autocomplete="tel" required pattern="\+?\d{7,15}"
                                   data-validate="phone"
                                   class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition invalid:border-rose invalid:bg-rose/5" />
                            <p class="text-xs text-ink/40 mt-1">7–15 digits, optional + country code.</p>
                            <p data-error="phone" class="text-xs text-rose mt-1 hidden"></p>
                        </div>

                        @* Owner-only fields *@
                        <div id="ownerOnly" class="space-y-4 @ownerOnlyClass">
                            <div>
                                <label class="pill text-ink/40 mb-2 block">Business / studio name</label>
                                <input asp-for="BusinessName" maxlength="120" minlength="2"
                                       data-validate="biz"
                                       placeholder="e.g. Acme Studio"
                                       class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                                <p class="text-xs text-ink/40 mt-1">2–120 characters. Shown across the system instead of your username.</p>
                                <p data-error="biz" class="text-xs text-rose mt-1 hidden"></p>
                            </div>
                            <div>
                                <label class="pill text-ink/40 mb-2 block">VAT registration</label>
                                <select asp-for="BusinessType" id="bizSelect"
                                        class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition">
                                    <option value="Patur">Osek Patur (VAT-exempt, ≤120k ₪/yr)</option>
                                    <option value="Murshe">Osek Murshe (regular 18% VAT)</option>
                                </select>
                                <p class="text-xs text-ink/40 mt-2">
                                    Patur invoices issue without 18% VAT. Murshe collects VAT on every sale (Form 836/874).
                                </p>
                            </div>
                            <label class="flex items-start gap-3 select-none cursor-pointer bg-paper-100/40 border border-black/5 rounded-2xl px-4 py-3">
                                <input asp-for="IsZair" type="checkbox" class="mt-1 accent-ink"/>
                                <span class="block">
                                    <span class="block font-semibold text-ink">Claim Osek Zair income-tax status</span>
                                    <span class="block text-xs text-ink/50 mt-1">
                                        Available if annual revenue ≤ ~122,833 ₪. Income tax on 70% of revenue (flat 30% deemed-expenses).
                                    </span>
                                </span>
                            </label>
                        </div>

                        @* Employee/Client field: company invite code (no public dropdown of every company) *@
                        <div id="inviteOnly" class="@inviteOnlyClass">
                            <label class="pill text-ink/40 mb-2 block">Company invite code</label>
                            <input asp-for="InviteCode" maxlength="16" pattern="[A-Z0-9\-]{4,16}"
                                   data-validate="invite"
                                   class="signup-field w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition uppercase tracking-widest"
                                   placeholder="e.g. ACME-7K3D" />
                            <p data-error="invite" class="text-xs text-rose mt-1 hidden"></p>
                            <p class="text-xs text-ink/40 mt-2">
                                Ask the Owner of the company you're joining for their invite code. We don't show a public list of companies for privacy reasons.
                            </p>
                        </div>

                        <div>
                            <label class="pill text-ink/40 mb-2 block">Preferred currency</label>
                            <select asp-for="Currency"
                                    class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition">
                                <option>ILS</option>
                                <option>USD</option>
                            </select>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <p class="text-rose text-sm">@Model.ErrorMessage</p>
                        }

                        <button type="submit"
                                class="group w-full inline-flex items-center justify-center gap-3 bg-ink text-paper-50 rounded-full px-6 py-3 mt-2 transition-all duration-500 ease-spring active:scale-[0.98]">
                            <span class="font-semibold">Create account</span>
                            <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center group-hover:translate-x-0.5 transition-all duration-500 ease-spring">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                            </span>
                        </button>
                    </form>
                </div>
            </div>

            <p class="text-center text-xs text-ink/40 mt-6">
                Already have an account?
                <a asp-page="/Login" class="text-accent hover:underline">Sign in</a>
            </p>
        </div>
    </div>
    @{
        var iSubDef   = "Pick the role that fits you.";
        var iSubOwn   = "Run the business — track invoices, expenses, VAT.";
        var iSubEmp   = "Join a company and log your work.";
        var iSubCli   = "View invoices, projects and contracts from your business.";
        var iErrUser  = "4–20 letters, digits, _ or . only.";
        var iErrPw    = "8+ chars and must include a letter and a digit.";
        var iErrEmail = "Looks invalid (e.g. name@@example.com).";
        var iErrPhone  = "7–15 digits, optional + country code.";
        var iErrBiz    = "Business name: 2–120 characters.";
        var iErrInvite = "Invite code looks like ACME-7K3D (4–16 chars, letters / digits / dash).";
    }
    <div id="i18n"
         data-subtitle-default="@iSubDef"
         data-subtitle-owner="@iSubOwn"
         data-subtitle-employee="@iSubEmp"
         data-subtitle-client="@iSubCli"
         data-err-username="@iErrUser"
         data-err-password="@iErrPw"
         data-err-email="@iErrEmail"
         data-err-phone="@iErrPhone"
         data-err-biz="@iErrBiz"
         data-err-invite="@iErrInvite"
         class="hidden"></div>
</section>

<script>
    var I18N = document.getElementById('i18n');
    function pickRole(role) {
        document.getElementById('selectedRoleHidden').value = role;
        document.getElementById('roleBadge').textContent = role.toUpperCase();
        document.getElementById('roleStep').classList.add('hidden');
        document.getElementById('formStep').classList.remove('hidden');
        var owner  = document.getElementById('ownerOnly');
        var invite = document.getElementById('inviteOnly');
        if (role === 'Owner') { owner.classList.remove('hidden'); invite.classList.add('hidden'); }
        else                  { owner.classList.add('hidden');    invite.classList.remove('hidden'); }
        var subKey = role === 'Owner' ? 'data-subtitle-owner'
                   : role === 'Client' ? 'data-subtitle-client'
                   : 'data-subtitle-employee';
        document.getElementById('subtitle').textContent = I18N.getAttribute(subKey);
    }
    function goBackToRole() {
        document.getElementById('selectedRoleHidden').value = '';
        document.getElementById('roleStep').classList.remove('hidden');
        document.getElementById('formStep').classList.add('hidden');
        document.getElementById('subtitle').textContent = I18N.getAttribute('data-subtitle-default');
    }
    (function () {
        var pw = document.getElementById('pwField');
        var hint = document.getElementById('pwHint');
        if (pw && hint) {
            function tick(sel, ok) {
                var el = hint.querySelector('[data-rule="' + sel + '"]');
                if (!el) return;
                el.classList.toggle('text-mint', !!ok);
                el.classList.toggle('text-ink/40', !ok);
            }
            pw.addEventListener('input', function () {
                var v = pw.value || '';
                tick('len',   v.length >= 8);
                tick('alpha', /[A-Za-z]/.test(v));
                tick('num',   /\d/.test(v));
            });
        }

        var rules = {
            username: { rx: /^[A-Za-z0-9_.]{4,20}$/,                 msg: I18N.getAttribute('data-err-username') },
            password: { test: function (v) { return /^(?=.*[A-Za-z])(?=.*\d).{8,}$/.test(v); }, msg: I18N.getAttribute('data-err-password') },
            email:    { rx: /^[\w.\-]+@@[\w\-]+\.[\w\-.]+$/,          msg: I18N.getAttribute('data-err-email') },
            phone:    { rx: /^\+?\d{7,15}$/,                          msg: I18N.getAttribute('data-err-phone') },
            biz:      { test: function (v) { var t = (v||'').trim(); return t.length >= 2 && t.length <= 120; },
                        msg: I18N.getAttribute('data-err-biz') },
            invite:   { test: function (v) { var t = (v||'').trim(); return /^[A-Z0-9\-]{4,16}$/.test(t); },
                        msg: I18N.getAttribute('data-err-invite') }
        };
        function showError(name, msg) {
            var el = document.querySelector('[data-error="' + name + '"]');
            if (!el) return;
            if (msg) { el.textContent = msg; el.classList.remove('hidden'); }
            else     { el.textContent = ''; el.classList.add('hidden'); }
        }
        function check(input, force) {
            var name = input.getAttribute('data-validate');
            if (!name) return true;
            var v = input.value || '';
            if (!v && !force) { showError(name, ''); input.classList.remove('border-rose'); input.classList.remove('bg-rose/5'); return false; }
            var r = rules[name];
            var ok = r.rx ? r.rx.test(v) : (r.test ? r.test(v) : true);
            if (!ok) {
                showError(name, r.msg);
                input.classList.add('border-rose');
                input.classList.add('bg-rose/5');
            } else {
                showError(name, '');
                input.classList.remove('border-rose'); input.classList.remove('bg-rose/5');
            }
            return ok;
        }
        document.querySelectorAll('.signup-field').forEach(function (el) {
            el.addEventListener('input', function () { check(el, false); });
            el.addEventListener('blur',  function () { check(el, true); });
        });
        var form = document.querySelector('#formStep form');
        if (form) form.addEventListener('submit', function (e) {
            var bad = false;
            document.querySelectorAll('.signup-field').forEach(function (el) {
                // Skip fields hidden by role-switching (offsetParent is null when display:none).
                if (el.offsetParent === null) return;
                if (!check(el, true)) bad = true;
            });
            if (bad) e.preventDefault();
        });
    })();
</script>
