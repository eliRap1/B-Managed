<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:BManagedMaui.Pages"
             x:Class="BManagedMaui.Pages.InvoicesPage"
             Title="Invoices">

    <Grid RowDefinitions="Auto,*">

        <Picker x:Name="FilterPicker" Title="Filter"
                Margin="16,12" SelectedIndexChanged="OnFilterChanged">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>All</x:String>
                    <x:String>Unpaid</x:String>
                    <x:String>Overdue</x:String>
                </x:Array>
            </Picker.ItemsSource>
        </Picker>

        <RefreshView x:Name="Refresh" Grid.Row="1" Refreshing="OnRefreshing">
            <CollectionView x:Name="InvoicesView" Margin="12,0,12,12">
                <CollectionView.EmptyView>
                    <Label Text="No invoices." TextColor="Gray"
                           HorizontalOptions="Center" Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="pages:InvoiceRow">
                        <Border Margin="0,6" Padding="14" BackgroundColor="White"
                                Stroke="#E5E7EB" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="8" RowSpacing="2">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Number}" FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Status}" FontSize="11" FontAttributes="Bold"
                                       TextColor="{Binding StatusColor}" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding DueText}" FontSize="12" TextColor="Gray" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding AmountText}" />
                                <Button Grid.Row="2" Grid.Column="1"
                                        Text="Mark paid"
                                        IsVisible="{Binding CanMarkPaid}"
                                        Clicked="OnMarkPaidClicked"
                                        CommandParameter="{Binding Id}"
                                        Padding="10,2" Margin="0,8,0,0" FontSize="12"
                                        HeightRequest="34" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
