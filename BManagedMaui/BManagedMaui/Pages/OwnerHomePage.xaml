<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BManagedMaui.Pages.OwnerHomePage"
             Title="Dashboard">

    <RefreshView x:Name="Refresh" Refreshing="OnRefreshing">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="14">

                <Label x:Name="GreetingLabel" FontSize="22" FontAttributes="Bold" />
                <Label x:Name="SubtitleLabel" FontSize="13" TextColor="{StaticResource TextMuted}" />

                <Grid x:Name="KpiGrid"
                      ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12" />

                <Label Text="Recent invoices" FontSize="17" FontAttributes="Bold" Margin="0,8,0,0" />
                <VerticalStackLayout x:Name="RecentList" Spacing="8" />

                <Label x:Name="EmptyLabel" IsVisible="False"
                       TextColor="{StaticResource TextMuted}" />

                <Button Text="Open invoices" Clicked="OnInvoicesClicked" Margin="0,12,0,0" />
                <Button Text="Sign out" Clicked="OnLogoutClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
