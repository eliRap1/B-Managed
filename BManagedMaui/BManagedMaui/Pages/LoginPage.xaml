<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BManagedMaui.Pages.LoginPage"
             Title="Sign in"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="16" VerticalOptions="Center">

            <Label Text="B-Managed"
                   FontSize="34" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />
            <Label Text="Your business, in your pocket"
                   FontSize="15" TextColor="{StaticResource TextMuted}"
                   HorizontalOptions="Center" />

            <Entry x:Name="UsernameEntry"
                   Placeholder="Username"
                   ReturnType="Next" />
            <Entry x:Name="PasswordEntry"
                   Placeholder="Password"
                   IsPassword="True"
                   ReturnType="Done"
                   Completed="OnLoginClicked" />

            <Button x:Name="LoginButton"
                    Text="Sign in"
                    Clicked="OnLoginClicked" />

            <ActivityIndicator x:Name="Busy"
                               IsRunning="False" IsVisible="False"
                               HorizontalOptions="Center" />

            <Label x:Name="ErrorLabel"
                   TextColor="Red" IsVisible="False"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="Tip: admin / admin1234"
                   FontSize="12" TextColor="{StaticResource TextMuted}"
                   HorizontalOptions="Center" Margin="0,8,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
